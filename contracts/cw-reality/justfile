default: build

build:
    cargo build --release --target wasm32-unknown-unknown --lib --locked

test:
    cargo test --locked

lint:
    cargo clippy --all-targets --locked -- -D warnings

schema:
    cargo run --example schema --locked

# Reproducible optimized wasm via the shared dao-contracts pattern. The root
# workspace is mounted because it owns Cargo.lock and the release profile.
workspace-optimize:
    #!/bin/bash
    set -euo pipefail
    root=$(git rev-parse --show-toplevel)
    cache="$(basename "$root")_cache"
    if [[ $(uname -m) == 'arm64' ]] || [[ $(uname -m) == 'aarch64' ]]; then \
        docker run --rm -v "$root":/code \
            --mount type=volume,source="$cache",target=/target \
            --mount type=volume,source=registry_cache,target=/usr/local/cargo/registry \
            --platform linux/arm64 \
            cosmwasm/optimizer-arm64:0.17.0; \
    elif [[ $(uname -m) == 'x86_64' ]]; then \
        docker run --rm -v "$root":/code \
            --mount type=volume,source="$cache",target=/target \
            --mount type=volume,source=registry_cache,target=/usr/local/cargo/registry \
            --platform linux/amd64 \
            cosmwasm/optimizer:0.17.0; \
    fi
